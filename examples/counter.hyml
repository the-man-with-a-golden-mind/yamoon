module: examples.counter

options:
  target: gall

macros:
  inc:
    args: [v]
    expand: v + 1

types:
  State:
    kind: record
    fields:
      count: number

functions:
  on-init:
    output: number
    return: inc(0)

  on-poke:
    input:
      val: number
    output: number
    return: inc(val)
